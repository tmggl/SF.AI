# SF.AI — Environment Variables Example
#
# انسخ هذا الملف إلى .env واملأ القيم محليًا.
# لا تضع أي API keys لخدمات ذكاء اصطناعي خارجية — هذا ممنوع بمبدأ السيادة المعرفية.
# لا ترفع .env إلى أي مستودع.

# ---------- API ----------
SF_API_HOST=127.0.0.1
# 8000/8765 may be used by other local projects; SF.AI chat uses 8123 by default.
SF_API_PORT=8123
SF_API_LOG_LEVEL=info

# ---------- App ----------
SF_ENV=development
SF_PROJECT_NAME=SF.AI

# ---------- PostgreSQL (Phase 1+ docker-compose) ----------
SF_POSTGRES_HOST=127.0.0.1
SF_POSTGRES_PORT=5432
SF_POSTGRES_USER=sfai
SF_POSTGRES_PASSWORD=change_me_locally
SF_POSTGRES_DB=sfai

# ---------- Redis (Phase 1+ docker-compose) ----------
SF_REDIS_HOST=127.0.0.1
SF_REDIS_PORT=6379

# ---------- Qdrant (Phase 8) ----------
SF_QDRANT_HOST=127.0.0.1
SF_QDRANT_PORT=6333

# ---------- Training / Device (Phase 5.5+) ----------
# auto | cpu | mps | cuda
SF_TRAINING_DEVICE=auto

# ---------- Runtime Lexicons ----------
# scripts/run_chat_server.sh and `make api` enable the user-authored Saudi Seed
# lexicon by default. Keep Mo3jam off unless you intentionally opt into import/use.
ENABLE_SAUDI_SEED_V1_LEXICON=true
ENABLE_MO3JAM_SAUDI_LEXICON=false

# ---------- Forbidden — DO NOT FILL ----------
# These exist only to document that they must remain unset.
# Any value here would violate sovereign principles.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
HUGGINGFACE_TOKEN=
